APP_NAME="Ad Monitoring System"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://admon:AdMon_12345!@db:5432/ad_monitoring
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Now only needed for non-proxied access (optional)
BACKEND_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080